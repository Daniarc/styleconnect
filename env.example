import { NextResponse } from "next/server";
import { openai } from "@/lib/openai/client";

export const runtime = "nodejs";

type Body = {
  outfitTitle?: string;
  tags?: string[];
  userText?: string;
};

export async function POST(req: Request) {
  try {
    const body = (await req.json()) as Body;

    const outfitTitle = (body.outfitTitle ?? "").slice(0, 120);
    const tags = Array.isArray(body.tags) ? body.tags.slice(0, 20) : [];
    const userText = (body.userText ?? "").slice(0, 2000);

    const input = [
      "Gib kurzes, hilfreiches Stil-Feedback auf Deutsch.",
      "Sei freundlich, konkret und umsetzbar. Keine Beleidigungen. Keine Diagnosen.",
      `Outfit-Titel: ${outfitTitle || "-"}`,
      `Tags: ${tags.length ? tags.join(", ") : "-"}`,
      `User-Notiz: ${userText || "-"}`,
      "",
      "Output Format:",
      "1) Kurzfazit (1 Satz)",
      "2) 3 konkrete Verbesserungsvorschläge (Bulletpoints)",
      "3) 2 alternative Kombi-Ideen (Bulletpoints)"
    ].join("\n");

    const resp = await openai.responses.create({
      model: "gpt-5.2",
      input
    });

    return NextResponse.json({ text: resp.output_text });
  } catch (e: any) {
    return NextResponse.json(
      { error: "AI_FEEDBACK_FAILED", detail: String(e?.message ?? e) },
      { status: 500 }
    );
  }
}
